module gol_display (
    input [63:0][63:0] grid,
    input [9:0] pixel_row,
    input [9:0] pixel_column,
    output reg pixel_out,
    output reg pixel_enable
);
    wire [5:0] col_index = pixel_column / 10;
    wire [5:0] row_index = pixel_row / 7;

    always @(*) begin
        if (pixel_column < 640 && pixel_row < 448) begin
            pixel_enable = 1'b1;
            pixel_out = grid[row_index][col_index];
        end else begin
            pixel_enable = 1'b0;
            pixel_out = 1'b0;
        end
    end
endmodule